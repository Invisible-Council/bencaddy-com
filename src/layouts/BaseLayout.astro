---
// BaseLayout — owns <html>, <head>, fonts and global styles.
// Fonts are hosted locally via @fontsource (replaces the Google Fonts CDN
// link from the prototype). Weights/styles match the prototype exactly:
//   Cormorant Garamond 300/400, normal + italic
//   Inter 300/400
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Ben Caddy' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />
  </body>
</html>
