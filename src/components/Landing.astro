---
// Landing — amber screen → main-site reveal transition.
//
// "Drift": on enter, the amber landing slowly pushes in and dims while a
// vignette blooms dark and then clears, and the site eases forward from a
// slight scale to settle into place. Slow and deliberate by intent.
---

<div id="landing" role="button" tabindex="0" aria-label="Enter site">
  <h1 id="landing-headline">You are living inside a story.</h1>
  <p id="landing-prompt">enter</p>
</div>

<script>
  (function () {
    const landing = document.getElementById('landing') as HTMLElement | null;
    const site = document.getElementById('site');
    if (!landing || !site) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let animating = false;
    function dissolve() {
      if (animating) return;
      animating = true;

      if (reduceMotion) {
        landing!.style.opacity = '0';
        site!.classList.add('visible');
        setTimeout(() => { landing!.style.display = 'none'; }, 300);
        return;
      }

      // Vignette overlay: blooms dark over the midpoint, then clears.
      const vig = document.createElement('div');
      Object.assign(vig.style, {
        position: 'fixed', inset: '0', zIndex: '150', pointerEvents: 'none',
        background: 'radial-gradient(circle at center, transparent 35%, rgba(0,0,0,0.85) 100%)',
        opacity: '0',
      } as CSSStyleDeclaration);
      document.body.appendChild(vig);

      // Site is revealed beneath the landing, easing forward as it settles.
      setTimeout(() => site!.classList.add('visible'), 200);
      site!.animate(
        [{ transform: 'scale(1.06)' }, { transform: 'scale(1)' }],
        { duration: 2000, easing: 'cubic-bezier(0.2, 0, 0.1, 1)' }
      );

      vig.animate(
        [{ opacity: 0 }, { opacity: 1, offset: 0.6 }, { opacity: 0 }],
        { duration: 2000, easing: 'ease-in-out', fill: 'forwards' }
      );

      landing!.animate(
        [
          { transform: 'scale(1)', opacity: 1, filter: 'brightness(1)' },
          { transform: 'scale(1.12)', opacity: 0, filter: 'brightness(0.6)' },
        ],
        { duration: 1900, easing: 'cubic-bezier(0.4, 0, 0.2, 1)', fill: 'forwards' }
      );

      setTimeout(() => { landing!.style.display = 'none'; }, 1900);
      setTimeout(() => vig.remove(), 2050);
    }

    landing.addEventListener('click', dissolve);
    landing.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') dissolve();
    });
  })();
</script>
