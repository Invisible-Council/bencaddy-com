---
// Landing — amber screen + particle dissolve transition.
// PORTED AS-IS from the prototype. Do not refine the transition here;
// transition iteration happens on the Vercel preview deploy.
---

<div id="landing" role="button" tabindex="0" aria-label="Enter site">
  <h1 id="landing-headline">You are living inside a story.</h1>
  <p id="landing-prompt">enter</p>
</div>

<canvas id="particle-canvas"></canvas>

<script>
  (function () {
    const landing = document.getElementById('landing');
    const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
    const site = document.getElementById('site');
    if (!landing || !canvas || !site) return;
    const ctx = canvas.getContext('2d')!;
    let particles: {
      x: number; y: number; size: number;
      angle: number; speed: number; delay: number;
    }[] = [];
    let animating = false, startTime: number | null = null;
    const DURATION = 2200, COUNT = 180;

    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }

    function buildParticles() {
      particles = [];
      for (let i = 0; i < COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: 1.5 + Math.random() * 3.5,
          angle: Math.random() * Math.PI * 2,
          speed: 0.3 + Math.random() * 1.2,
          delay: Math.random() * 600,
        });
      }
    }

    function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    function animate(ts: number) {
      if (!startTime) startTime = ts;
      const elapsed = ts - startTime;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let allDone = true;
      particles.forEach(p => {
        const t = Math.max(0, (elapsed - p.delay) / DURATION);
        if (t < 1) allDone = false;
        const e = easeOut(Math.min(t, 1));
        ctx.save();
        ctx.globalAlpha = Math.max(0, 1 - e * 1.1) * 0.75;
        ctx.fillStyle = '#E8973A';
        ctx.beginPath();
        ctx.arc(
          p.x + Math.cos(p.angle) * p.speed * e * 280,
          p.y + Math.sin(p.angle) * p.speed * e * 280,
          p.size * (1 - e * 0.5), 0, Math.PI * 2
        );
        ctx.fill();
        ctx.restore();
      });
      if (allDone) { canvas.style.display = 'none'; return; }
      requestAnimationFrame(animate);
    }

    function dissolve() {
      if (animating) return;
      animating = true;
      resize(); buildParticles();
      canvas.style.display = 'block';
      landing!.style.opacity = '0';
      setTimeout(() => { landing!.style.display = 'none'; }, 650);
      setTimeout(() => { site!.classList.add('visible'); }, 400);
      startTime = null;
      requestAnimationFrame(animate);
    }

    landing.addEventListener('click', dissolve);
    landing.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') dissolve(); });
    window.addEventListener('resize', resize);
    resize();
  })();
</script>
